{
  "name": "codex-telegram",
  "version": "0.1.0",
  "description": "Telegram bridge for managing Codex agents on Windows",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
